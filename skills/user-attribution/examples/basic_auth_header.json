{
  "projector": {
    "attributeProjector": {
      "attributeKey": "http.request.header.authorization",
      "attributeRule": {
        "projector": {
          "regexCaptureGroupProjector": {
            "regexCaptureGroup": "^(?i:Basic) (.*)$",
            "attributeRule": {
              "projector": {
                "base64Projector": {
                  "attributeRule": {
                    "projector": {
                      "regexCaptureGroupProjector": {
                        "regexCaptureGroup": "^([^:]*)",
                        "attributeRule": {
                          "initialActions": [
                            {
                              "attributeAddition": {
                                "attributeKey": "enduser.id",
                                "valueProjectionRule": {
                                  "projector": { "noOpProjector": {} }
                                }
                              }
                            },
                            {
                              "attributeArrayAppend": {
                                "attributeKey": "traceableai.auth.types",
                                "valueProjectionRule": {
                                  "projector": {
                                    "valueProjector": { "value": "Basic" }
                                  }
                                }
                              }
                            }
                          ]
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
